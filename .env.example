# ─────────────────────────────────────────────────────────────
#  Zero Agency · Notion Interno Omnicanal — Variables de entorno
# ─────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y completa los valores reales.
# Ninguna de estas claves se commitea al repositorio.

# Gmail / Google OAuth (correo de la agencia)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback
# Cuenta de la agencia usada como contexto del dashboard
AGENCY_EMAIL=principal.zeroagency@gmail.com

# Google Drive (usa el mismo OAuth de Google con scope de Drive)
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# GitHub (App o Personal Access Token)
GITHUB_TOKEN=
GITHUB_DEFAULT_ORG=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Clave de la API de Claude para el asistente / resúmenes (opcional)
ANTHROPIC_API_KEY=
