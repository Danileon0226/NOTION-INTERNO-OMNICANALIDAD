# ─────────────────────────────────────────────────────────────
#  Zero Agency · Notion Interno Omnicanal — Variables de entorno
# ─────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y completa los valores reales.
# Ninguna de estas claves se commitea al repositorio.

# Gmail / Google OAuth (correo de la agencia)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback
# Cuenta de la agencia usada como contexto del dashboard
AGENCY_EMAIL=equipo@tu-agencia.com

# Google Drive (usa el mismo OAuth de Google con scope de Drive)
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# GitHub (App o Personal Access Token)
GITHUB_TOKEN=
GITHUB_DEFAULT_ORG=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Clave de la API de Claude para el asistente / resúmenes (opcional)
ANTHROPIC_API_KEY=

# Nota: el asistente Gemini ("Zero") es client-side (la app se exporta a
# GitHub Pages, sin servidor). Su API key NO va aquí: se pega en la propia
# app, en Conectores → Asistente IA, y se guarda en el navegador.

# ─────────────────────────────────────────────────────────────
#  Cliente (NEXT_PUBLIC_*) — se incrustan en el navegador.
#  Úsalas para apuntar la app desplegada a tu cuenta REAL con 1 clic.
#  El Client ID de OAuth NO es secreto; el correo es solo para mostrar.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_AGENCY_EMAIL=

# Subruta para GitHub Pages (project site), p. ej. /NOTION-INTERNO-OMNICANALIDAD
NEXT_PUBLIC_BASE_PATH=

# ─────────────────────────────────────────────────────────────
#  Login por clave (opcional). Si defines alguna, la app pide clave
#  para entrar (la landing y la documentación quedan públicas).
#  Recomendado el hash: la clave no queda en el bundle.
#    Hash:  echo -n "tu-clave" | shasum -a 256
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_PASSWORD=
NEXT_PUBLIC_APP_PASSWORD_SHA256=
